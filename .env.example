# ══════════════════════════════════════════════════════════════
# AgriSaathi — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# All features work in SIMULATION MODE when keys are empty.
# ══════════════════════════════════════════════════════════════

# ── LLM (AI Brain) ───────────────────────────────────────────
# Get Groq key (FREE): https://console.groq.com/keys
GROQ_API_KEY=

# Get Gemini key (FREE): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Weather (OpenWeather) ────────────────────────────────────
# Get FREE key: https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=

# ── WhatsApp (Meta Cloud API) ────────────────────────────────
# Get from https://developers.facebook.com/
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WEBHOOK_VERIFY_TOKEN=

# ── Telegram Bot ─────────────────────────────────────────────
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Satellite (Sentinel Hub) ─────────────────────────────────
# Register: https://shub.sentinel-hub.com
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=

# ── Government Data ──────────────────────────────────────────
# Register: https://data.gov.in
DATA_GOV_API_KEY=

# ── Supabase (Database) ─────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
